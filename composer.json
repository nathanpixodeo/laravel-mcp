{
    "name": "nathan/laravel-mcp",
    "description": "MCP (Model Context Protocol) server for Laravel - cho phép AI agents debug production/demo qua CLI",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "mcp/sdk": "^0.6"
    },
    "suggest": {
        "nyholm/psr7": "Required for HTTP transport support",
        "nyholm/psr7-server": "Required for HTTP transport support"
    },
    "autoload": {
        "psr-4": {
            "Nathan\\LaravelMcp\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nathan\\LaravelMcp\\McpServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
